{
  "name": "@twilic/core",
  "version": "3.0.0",
  "description": "Node.js and TypeScript implementation of a fast, compact binary wire format for modern data transport.",
  "type": "module",
  "packageManager": "pnpm@10.18.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/twilic/twilic-js.git"
  },
  "homepage": "https://github.com/twilic/twilic-js#readme",
  "bugs": {
    "url": "https://github.com/twilic/twilic-js/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "import": "./dist/advanced.js",
      "default": "./dist/advanced.js"
    }
  },
  "files": [
    "dist",
    "native",
    "wasm/pkg",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "pnpm build:napi && pnpm build:wasm && pnpm build:ts",
    "build:ts": "tsc -p tsconfig.json",
    "build:napi": "cargo build --locked --manifest-path Cargo.toml -p twilic-napi --release && node ./scripts/copy-napi.mjs",
    "build:wasm": "wasm-pack build crates/twilic-wasm --target bundler --out-dir ../../wasm/pkg --out-name twilic_wasm --no-opt -- --locked && rm -f wasm/pkg/.gitignore",
    "verify:pack": "node ./scripts/verify-pack-contents.mjs",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint src scripts tests",
    "lint:fix": "oxlint --fix src scripts tests",
    "typecheck": "tsc --noEmit",
    "test:rust": "cargo test --locked --manifest-path Cargo.toml -p twilic-bridge",
    "test:node": "pnpm build:napi && pnpm build:ts && node --test --test-concurrency=1 \"tests/**/*.test.mjs\"",
    "test": "pnpm test:rust && pnpm test:node",
    "prepack": "pnpm build",
    "release:check": "node ./scripts/verify-tag-version.mjs",
    "clean": "rimraf dist native wasm target",
    "prepare": "husky"
  },
  "keywords": [
    "@twilic/core",
    "twilic",
    "rust",
    "napi",
    "wasm",
    "typescript"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/node": "^24.1.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.65.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  }
}
